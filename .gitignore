# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
.claude

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Large source video files. Keep the small /web/ versions and the parent
# review clips referenced by code; exclude the uncompressed originals.
public/videos/*.mp4
public/videos/*.MP4
public/videos/*.mov
public/videos/*.MOV
# Whitelist the compressed clips the site actually uses:
!public/videos/Mr. & Mrs. Abu Parents Review.mp4
!public/videos/Mrs. Amos-Penda Parents Review.mp4
!public/videos/Engineer Shok Julius Parents Review.mp4
!public/videos/Parents as the 1st Educators.mp4
!public/videos/web/
